<view class="section">
  <view class="card shadow-card admin-card">
    <text class="admin-title">系统管理</text>
    <text class="admin-sub">仅系统管理员可见</text>
  </view>
</view>

<view class="section">
  <view class="card shadow-card admin-menu">
    <view class="admin-setting-item">
      <view class="admin-setting-body">
        <text class="admin-setting-title">创建活动开关</text>
        <text class="admin-setting-desc">开启后仅系统管理员可创建活动</text>
      </view>
      <switch
        checked="{{createActivityAdminOnly}}"
        bindchange="onCreateActivitySwitchChange"
        disabled="{{savingCreateActivitySwitch}}"
        color="#3b82f6"
      />
    </view>
    <view class="admin-menu-divider"></view>
    <view class="admin-menu-item" bindtap="goActivities">
      <view class="admin-menu-icon">📋</view>
      <view class="admin-menu-body">
        <text class="admin-menu-title">活动列表</text>
        <text class="admin-menu-desc">查看系统内全部活动</text>
      </view>
      <text class="admin-menu-arrow">→</text>
    </view>
    <view class="admin-menu-divider"></view>
    <view class="admin-menu-item" bindtap="goFeedback">
      <view class="admin-menu-icon">📦</view>
      <view class="admin-menu-body">
        <text class="admin-menu-title">反馈管理</text>
        <text class="admin-menu-desc">查看与处理用户反馈</text>
      </view>
      <text class="admin-menu-arrow">→</text>
    </view>
  </view>
</view>