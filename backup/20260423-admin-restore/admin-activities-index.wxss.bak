.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.search-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.search-btn {
  flex-shrink: 0;
}

.type-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.type-list {
  display: inline-flex;
  gap: 16rpx;
}

.type-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #4b5563;
  font-size: 26rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.type-chip--active {
  background: #3b82f6;
  color: #fff;
}

.activity-card {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.activity-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.activity-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.activity-status {
  color: #2563eb;
  font-size: 24rpx;
}

.activity-meta {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  color: #6b7280;
  font-size: 26rpx;
}

.activity-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.state-card,
.state-footer {
  text-align: center;
  color: #6b7280;
  font-size: 26rpx;
  padding: 40rpx 0;
}