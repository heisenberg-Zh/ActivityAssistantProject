<view class="page">
  <view class="search-card">
    <input class="search-input" placeholder="搜索活动名称" value="{{keywordDraft}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onSearch" />
    <button class="search-btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <scroll-view scroll-x class="type-scroll" show-scrollbar="false">
    <view class="type-list">
      <block wx:for="{{typeOptions}}" wx:key="*this">
        <view class="type-chip {{selectedType === item ? 'type-chip--active' : ''}}" data-type="{{item}}" bindtap="onTypeTap">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="state-card">加载中...</view>
  <view wx:elif="{{!activities.length}}" class="state-card">暂无活动</view>

  <block wx:for="{{activities}}" wx:key="id">
    <view class="activity-card">
      <view class="activity-head">
        <text class="activity-title">{{item.title}}</text>
        <text class="activity-status">{{item.statusText}}</text>
      </view>
      <view class="activity-meta">
        <text>类型：{{item.type || '未分类'}}</text>
        <text>人数：{{item.joinedText}}</text>
      </view>
      <view class="activity-meta">
        <text>时间：{{item.timeText}}</text>
      </view>
      <view class="activity-meta">
        <text>地点：{{item.placeText || '未填写'}}</text>
      </view>
      <view class="activity-actions">
        <button size="mini" bindtap="goDetail" data-id="{{item.id}}">查看详情</button>
        <button size="mini" type="primary" bindtap="goManage" data-id="{{item.id}}">进入管理</button>
      </view>
    </view>
  </block>

  <view wx:if="{{loadingMore}}" class="state-footer">加载更多中...</view>
  <view wx:elif="{{activities.length && !hasMore}}" class="state-footer">已加载全部活动</view>
</view>