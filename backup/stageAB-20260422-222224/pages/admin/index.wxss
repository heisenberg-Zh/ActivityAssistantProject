.admin-card {
  padding: 28rpx 24rpx;
}

.admin-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.admin-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.admin-menu {
  padding: 8rpx 0;
}

.admin-setting-item {
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx;
}

.admin-setting-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.admin-setting-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.admin-setting-desc {
  font-size: 24rpx;
  color: #6b7280;
}

.admin-menu-divider {
  height: 1rpx;
  background: #eef2f7;
  margin: 0 20rpx;
}

.admin-menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx;
}

.admin-menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #eef2ff;
  color: #3730a3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.admin-menu-body {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.admin-menu-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.admin-menu-desc {
  font-size: 24rpx;
  color: #6b7280;
}

.admin-menu-arrow {
  font-size: 34rpx;
  color: #9ca3af;
  margin-left: 12rpx;
}
