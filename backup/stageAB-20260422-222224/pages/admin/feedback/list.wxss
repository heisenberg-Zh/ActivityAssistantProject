.filter-scroll {
  width: 100%;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 0 6rpx 14rpx;
}

.filter-tab {
  padding: 12rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: rgba(17, 24, 39, 0.04);
  white-space: nowrap;
}

.filter-tab--active {
  background: rgba(59, 130, 246, 0.12);
  color: #2563eb;
  font-weight: 700;
}

.search-bar {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #eef2f7;
  background: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-btn {
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111827;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.feedback-item {
  padding: 18rpx 18rpx;
  margin-bottom: 16rpx;
}

.feedback-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f3f4f6;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #111827, #374151);
}

.avatar-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  padding: 8rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.badge--pending {
  background: rgba(245, 158, 11, 0.16);
  color: #b45309;
}

.badge--processing {
  background: rgba(59, 130, 246, 0.14);
  color: #1d4ed8;
}

.badge--resolved {
  background: rgba(16, 185, 129, 0.16);
  color: #047857;
}

.badge--closed {
  background: rgba(107, 114, 128, 0.14);
  color: #374151;
}

.sub-row {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.sub {
  font-size: 22rpx;
  color: #6b7280;
}

.feedback-body {
  margin-top: 14rpx;
}

.content {
  font-size: 26rpx;
  color: #111827;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-state {
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.loading-more {
  padding: 20rpx 0 40rpx;
  text-align: center;
}

.loading-text {
  font-size: 24rpx;
  color: #9ca3af;
}

