/* pages/management/registrations.wxss */

.registrations-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 80rpx;
}

/* 筛选标签 */
.supplement-tools {
  margin: 18rpx 24rpx 12rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #edf1f7;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
}

.supplement-tools__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.supplement-tools__title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.supplement-tools__desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b95a5;
}

.supplement-tools__count {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
}

.supplement-tools__actions {
  display: flex;
  gap: 14rpx;
}

.supplement-action {
  flex: 1;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.supplement-action--manual {
  color: #2563eb;
  background: #eff6ff;
}

.supplement-action--code {
  color: #059669;
  background: #ecfdf5;
}

.supplement-action__icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 12rpx;
  line-height: 34rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.82);
}

.supplement-dialog {
  width: 660rpx;
  border-radius: 30rpx;
  max-height: 84vh;
}

.supplement-dialog__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 34rpx 36rpx 22rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.supplement-dialog__title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #111827;
}

.supplement-dialog__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8b95a5;
}

.supplement-dialog__close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 38rpx;
  line-height: 52rpx;
  text-align: center;
}

.supplement-dialog__body {
  max-height: 58vh;
  padding: 24rpx 36rpx 10rpx;
  box-sizing: border-box;
}

.supplement-field {
  margin-bottom: 24rpx;
}

.supplement-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #374151;
}

.supplement-input {
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

.supplement-picker {
  line-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.supplement-picker__arrow {
  color: #9ca3af;
  font-size: 36rpx;
}

.supplement-note {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 23rpx;
  line-height: 1.5;
}

.supplement-dialog__footer {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 36rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f1f5f9;
}

.supplement-dialog__btn {
  flex: 1;
  height: 78rpx;
  border-radius: 20rpx;
  line-height: 78rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.supplement-dialog__btn--ghost {
  color: #4b5563;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
}

.supplement-dialog__btn--primary {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.22);
}

.code-dialog {
  position: relative;
  width: 610rpx;
  padding: 48rpx 42rpx 38rpx;
  border-radius: 32rpx;
  align-items: center;
  box-sizing: border-box;
}

.code-dialog__close {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 38rpx;
  line-height: 50rpx;
  text-align: center;
}

.code-dialog__eyebrow {
  font-size: 24rpx;
  font-weight: 800;
  color: #059669;
}

.code-dialog__code {
  margin-top: 22rpx;
  padding: 20rpx 48rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  color: #065f46;
  font-size: 72rpx;
  font-weight: 900;
  letter-spacing: 12rpx;
  text-align: center;
}

.code-dialog__message {
  margin-top: 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  text-align: center;
}

.code-dialog__hint {
  margin-top: 14rpx;
  color: #8b95a5;
  font-size: 23rpx;
  line-height: 1.45;
  text-align: center;
}

.code-dialog__button {
  width: 100%;
  height: 78rpx;
  margin-top: 30rpx;
  border-radius: 22rpx;
  background: #111827;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 78rpx;
  text-align: center;
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
  padding: 14rpx 24rpx 16rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
}

.filter-tab {
  flex: 1;
  padding: 12rpx;
  text-align: center;
  background: #f3f4f6;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  transition: all 0.3s ease;
}

.filter-tab--active {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  font-weight: 600;
}

/* 列表样式 */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  padding: 22rpx;
  border-radius: 20rpx;
}

.list-avatar-container {
  width: 80rpx;
  height: 80rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.list-avatar {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
}

.list-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.list-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.list-mobile {
  font-size: 24rpx;
  color: #6b7280;
}

.list-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.list-status {
  flex-shrink: 0;
  margin-right: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.status-badge {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.status-badge--success {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  color: #059669;
}

.status-badge--warning {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #d97706;
}

.status-badge--danger {
  background: linear-gradient(135deg, #fee2e2, #fecaca);
  color: #dc2626;
}

.status-badge--default {
  background: #e5e7eb;
  color: #6b7280;
}

.list-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-top: 26rpx;
}

/* 对话框样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-content {
  width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dialog-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #6b7280;
}

.dialog-body {
  flex: 1;
  overflow-y: auto;
}

.dialog-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #e5e7eb;
}

.dialog-footer .btn {
  flex: 1;
}

/* 移除模式 */
.remove-mode {
  padding: 16rpx 24rpx;
}

.remove-hint {
  margin-bottom: 16rpx;
}

.user-info-card {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.text-base {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.text-sm {
  font-size: 24rpx;
}

.text-gray-500 {
  color: #6b7280;
}

.text-gray-600 {
  color: #4b5563;
}

/* 切换开关组 */
.toggle-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin: 16rpx 0;
  border-top: 1rpx solid #e5e7eb;
  border-bottom: 1rpx solid #e5e7eb;
}

.toggle-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* 输入组 */
.input-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.input-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.reason-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  min-height: 400rpx;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9ca3af;
}

/* =========================
 * 报名详情 Bottom Sheet（简洁高级）
 * ========================= */
.detail-overlay {
  align-items: center;
}

.detail-sheet {
  width: 680rpx;
  width: 92%;
  max-width: 680rpx;
  max-height: 78vh;
  border-radius: 24rpx;
}

.detail-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.detail-sheet__user {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-sheet__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f3f4f6;
}

.detail-sheet__avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
}

.detail-sheet__avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #111827, #374151);
}

.detail-sheet__avatar-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.detail-sheet__user-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detail-sheet__title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.detail-sheet__name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sheet__tag {
  padding: 6rpx 12rpx;
  border-radius: 9999rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sheet__sub-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.detail-sheet__status {
  padding: 6rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
}

.detail-sheet__sub {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sheet__close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: rgba(17, 24, 39, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 26rpx;
  flex-shrink: 0;
}

.detail-sheet__body {
  flex: 1;
  padding: 0;
}

.detail-sheet__content {
  padding: 8rpx 40rpx 16rpx;
  box-sizing: border-box;
}

.detail-sheet__kv {
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #eef2f7;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.detail-kv-row {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  padding: 18rpx 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.detail-kv-row:last-child {
  border-bottom: none;
}

.detail-kv-label {
  flex: 1 1 0;
  min-width: 0;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.4;
  text-align: left;
  padding-right: 16rpx;
  box-sizing: border-box;
}

.detail-kv-value {
  flex: 1 1 0;
  min-width: 0;
  font-size: 26rpx;
  color: #111827;
  line-height: 1.5;
  text-align: left;
  border-left: 1rpx solid #eef2f7;
  padding-left: 16rpx;
  box-sizing: border-box;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.detail-kv-value--danger {
  color: #dc2626;
}

.detail-kv-label text,
.detail-kv-value text {
  display: block;
  max-width: 100%;
}

.detail-sheet__empty {
  padding: 40rpx 8rpx 56rpx;
  text-align: center;
}

.detail-sheet__empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.detail-sheet__empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.detail-sheet__actions {
  padding: 20rpx 40rpx 34rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), #ffffff);
  border-top: 1rpx solid #eef2f7;
}

.detail-action {
  height: 84rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 84rpx;
  border: none;
}

.detail-action--primary {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.22);
}
