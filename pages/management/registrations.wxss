/* pages/management/registrations.wxss */

.registrations-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 80rpx;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
}

.filter-tab {
  flex: 1;
  padding: 12rpx;
  text-align: center;
  background: #f3f4f6;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  transition: all 0.3s ease;
}

.filter-tab--active {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  font-weight: 600;
}

/* 列表样式 */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 20rpx;
}

.list-avatar-container {
  width: 80rpx;
  height: 80rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.list-avatar {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
}

.list-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.list-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.list-mobile {
  font-size: 24rpx;
  color: #6b7280;
}

.list-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.list-status {
  flex-shrink: 0;
  margin-right: 12rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.status-badge--success {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  color: #059669;
}

.status-badge--warning {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #d97706;
}

.status-badge--danger {
  background: linear-gradient(135deg, #fee2e2, #fecaca);
  color: #dc2626;
}

.status-badge--default {
  background: #e5e7eb;
  color: #6b7280;
}

.list-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

/* 对话框样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-content {
  width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.dialog-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #6b7280;
}

.dialog-body {
  flex: 1;
  overflow-y: auto;
}

.dialog-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #e5e7eb;
}

.dialog-footer .btn {
  flex: 1;
}

/* 移除模式 */
.remove-mode {
  padding: 16rpx 24rpx;
}

.remove-hint {
  margin-bottom: 16rpx;
}

.user-info-card {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.text-base {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.text-sm {
  font-size: 24rpx;
}

.text-gray-500 {
  color: #6b7280;
}

.text-gray-600 {
  color: #4b5563;
}

/* 切换开关组 */
.toggle-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin: 16rpx 0;
  border-top: 1rpx solid #e5e7eb;
  border-bottom: 1rpx solid #e5e7eb;
}

.toggle-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* 输入组 */
.input-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.input-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.reason-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  min-height: 400rpx;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9ca3af;
}

/* =========================
 * 报名详情 Bottom Sheet（简洁高级）
 * ========================= */
.detail-overlay {
  align-items: center;
}

.detail-sheet {
  width: 680rpx;
  width: 92%;
  max-width: 680rpx;
  max-height: 78vh;
  border-radius: 24rpx;
}

.detail-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 20rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.detail-sheet__user {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-sheet__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f3f4f6;
}

.detail-sheet__avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
}

.detail-sheet__avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #111827, #374151);
}

.detail-sheet__avatar-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.detail-sheet__user-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detail-sheet__title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.detail-sheet__name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sheet__tag {
  padding: 6rpx 12rpx;
  border-radius: 9999rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sheet__sub-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.detail-sheet__status {
  padding: 6rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
}

.detail-sheet__sub {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-sheet__close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: rgba(17, 24, 39, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 26rpx;
  flex-shrink: 0;
}

.detail-sheet__body {
  flex: 1;
  padding: 0;
}

.detail-sheet__content {
  padding: 8rpx 40rpx 16rpx;
  box-sizing: border-box;
}

.detail-sheet__kv {
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #eef2f7;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.detail-kv-row {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  padding: 18rpx 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.detail-kv-row:last-child {
  border-bottom: none;
}

.detail-kv-label {
  flex: 1 1 0;
  min-width: 0;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.4;
  text-align: left;
  padding-right: 16rpx;
  box-sizing: border-box;
}

.detail-kv-value {
  flex: 1 1 0;
  min-width: 0;
  font-size: 26rpx;
  color: #111827;
  line-height: 1.5;
  text-align: left;
  border-left: 1rpx solid #eef2f7;
  padding-left: 16rpx;
  box-sizing: border-box;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.detail-kv-value--danger {
  color: #dc2626;
}

.detail-kv-label text,
.detail-kv-value text {
  display: block;
  max-width: 100%;
}

.detail-sheet__empty {
  padding: 40rpx 8rpx 56rpx;
  text-align: center;
}

.detail-sheet__empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.detail-sheet__empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9ca3af;
}
