.export-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 10% 6%, rgba(20, 184, 166, 0.16), transparent 34%),
    radial-gradient(circle at 92% 16%, rgba(59, 130, 246, 0.16), transparent 28%),
    linear-gradient(180deg, #f8fafc 0%, #eef6ff 100%);
}

.hero-card,
.section-card {
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-sizing: border-box;
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
}

.hero-card::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.12);
}

.hero-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 44rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 118, 110, 0.28);
  flex-shrink: 0;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: 1rpx;
}

.hero-desc {
  font-size: 25rpx;
  color: #64748b;
  line-height: 1.55;
}

.section-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-subtitle {
  font-size: 23rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.rule-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #14b8a6;
  box-shadow: 0 0 0 8rpx rgba(20, 184, 166, 0.12);
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #334155;
}

.date-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.date-field {
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  border: 1rpx solid #dbeafe;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.date-field:active {
  transform: scale(0.99);
}

.date-label {
  font-size: 23rpx;
  color: #64748b;
}

.date-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f766e;
}

.date-value.is-muted {
  color: #94a3b8;
}

.action-row {
  display: flex;
  gap: 18rpx;
}

.action-btn {
  margin: 0;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.action-btn::after {
  border: none;
}

.action-btn--primary {
  flex: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e 0%, #2563eb 100%);
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.24);
}

.action-btn--plain {
  width: 190rpx;
  color: #0f766e;
  background: #ecfeff;
}

.hint-card {
  padding: 24rpx 28rpx;
  border-radius: 26rpx;
  background: rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hint-title {
  font-size: 25rpx;
  font-weight: 700;
  color: #334155;
}

.hint-text {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.55;
}
