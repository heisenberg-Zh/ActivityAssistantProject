.admin-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f7fb 0%, #eef2f7 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.admin-hero {
  position: relative;
  overflow: hidden;
  padding: 32rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
}

.admin-hero::after {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -90rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.18) 0%, rgba(59, 130, 246, 0) 72%);
}

.admin-hero__badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 9999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
}

.admin-hero__title {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.3;
  color: #0f172a;
  font-weight: 700;
}

.admin-hero__desc {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.admin-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.06);
}

.admin-panel__header {
  padding: 6rpx 6rpx 20rpx;
}

.admin-panel__title {
  display: block;
  font-size: 34rpx;
  color: #111827;
  font-weight: 700;
}

.admin-panel__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.admin-switch-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 12rpx 26rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.admin-switch-row__body {
  flex: 1;
  min-width: 0;
}

.admin-switch-row__title {
  display: block;
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
}

.admin-switch-row__desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.admin-menu-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-top: 22rpx;
}

.admin-menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 16rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.admin-menu-item__icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.admin-menu-item__icon--amber {
  background: linear-gradient(135deg, #fff7ed 0%, #fed7aa 100%);
}

.admin-menu-item__icon--rose {
  background: linear-gradient(135deg, #fff1f2 0%, #fecdd3 100%);
}

.admin-menu-item__body {
  flex: 1;
  min-width: 0;
}

.admin-menu-item__title {
  display: block;
  font-size: 30rpx;
  color: #111827;
  font-weight: 700;
}

.admin-menu-item__desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.admin-menu-item__arrow {
  flex-shrink: 0;
  font-size: 34rpx;
  color: #94a3b8;
  line-height: 1;
}
