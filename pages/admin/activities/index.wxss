.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2f8 0%, #f7f9fc 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card {
  padding: 26rpx 26rpx 24rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.24) 0%, rgba(37, 99, 235, 0) 32%),
    linear-gradient(135deg, #0f172a 0%, #172554 52%, #0f3b66 100%);
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.22);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 9999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.88);
  font-size: 20rpx;
  font-weight: 600;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(226, 232, 240, 0.82);
  font-size: 24rpx;
  line-height: 1.7;
}

.stats-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  backdrop-filter: blur(16rpx);
}

.stat-card--total {
  background: rgba(15, 23, 42, 0.55);
}

.stat-card--ongoing {
  background: rgba(20, 83, 45, 0.42);
}

.stat-card--finished {
  background: rgba(51, 65, 85, 0.4);
}

.stat-card--cancelled {
  background: rgba(127, 29, 29, 0.35);
}

.stat-value {
  display: block;
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: rgba(226, 232, 240, 0.82);
  font-size: 22rpx;
}

.filter-card {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

.search-btn {
  flex-shrink: 0;
  width: 132rpx;
  height: 78rpx;
  line-height: 78rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.search-btn::after {
  border: none;
}

.status-scroll,
.type-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.chip-list {
  display: inline-flex;
  gap: 14rpx;
}

.chip {
  min-width: 110rpx;
  height: 60rpx;
  padding: 0 22rpx;
  border-radius: 9999rpx;
  background: #0f172a;
  color: rgba(226, 232, 240, 0.8);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.chip--active {
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
}

.chip--light {
  background: #f8fafc;
  color: #64748b;
  box-shadow: inset 0 0 0 1rpx #e2e8f0;
}

.chip--active-light {
  background: #e0edff;
  color: #1d4ed8;
  box-shadow: inset 0 0 0 1rpx rgba(37, 99, 235, 0.16);
}

.state-card {
  margin-top: 24rpx;
  padding: 60rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.state-card--empty {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.state-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.state-desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.7;
}

.state-btn {
  margin-top: 22rpx;
  min-width: 180rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 9999rpx;
  background: #e0edff;
  color: #1d4ed8;
  font-size: 24rpx;
  line-height: 64rpx;
}

.activity-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #11203c 0%, #111827 100%);
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.18);
}

.activity-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.badge-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.badge--status-registering {
  background: #86efac;
  color: #14532d;
}

.badge--status-upcoming {
  background: #dbeafe;
  color: #1d4ed8;
}

.badge--status-ongoing {
  background: #bfdbfe;
  color: #1e3a8a;
}

.badge--status-finished {
  background: #e5e7eb;
  color: #334155;
}

.badge--status-cancelled {
  background: #fecaca;
  color: #991b1b;
}

.badge--visibility {
  background: rgba(255, 255, 255, 0.1);
}

.badge--visibility-private {
  color: #fbcfe8;
}

.badge--visibility-public {
  color: #dbeafe;
}

.activity-title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 700;
}

.activity-meta-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.activity-meta-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.activity-meta-item--inline {
  align-items: center;
}

.activity-meta-label {
  flex-shrink: 0;
  width: 92rpx;
  color: rgba(148, 163, 184, 0.9);
  font-size: 24rpx;
}

.activity-meta-value {
  flex: 1;
  color: rgba(241, 245, 249, 0.96);
  font-size: 25rpx;
  line-height: 1.6;
}

.activity-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 74rpx;
  line-height: 74rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn--ghost {
  background: rgba(15, 23, 42, 0.36);
  color: #cbd5e1;
  box-shadow: inset 0 0 0 1rpx rgba(148, 163, 184, 0.18);
}

.action-btn--warn {
  background: rgba(245, 158, 11, 0.16);
  color: #fbbf24;
  box-shadow: inset 0 0 0 1rpx rgba(245, 158, 11, 0.22);
}

.action-btn--danger {
  background: rgba(239, 68, 68, 0.16);
  color: #fca5a5;
  box-shadow: inset 0 0 0 1rpx rgba(239, 68, 68, 0.22);
}

.action-btn--disabled {
  opacity: 0.36;
}

.manage-hint {
  display: block;
  margin-top: 16rpx;
  color: rgba(148, 163, 184, 0.82);
  font-size: 22rpx;
}
