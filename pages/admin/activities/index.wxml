<view class="page">
  <view class="hero-card">
    <view class="hero-badge">系统管理员 · 活动治理台</view>
    <text class="hero-title">活动治理台</text>
    <text class="hero-desc">全量活动一键取消/删除与快速巡查</text>

    <view class="stats-grid">
      <view class="stat-card stat-card--total">
        <text class="stat-value">{{stats.total}}</text>
        <text class="stat-label">活动总数</text>
      </view>
      <view class="stat-card stat-card--ongoing">
        <text class="stat-value">{{stats.ongoing}}</text>
        <text class="stat-label">进行中</text>
      </view>
      <view class="stat-card stat-card--finished">
        <text class="stat-value">{{stats.finished}}</text>
        <text class="stat-label">已结束</text>
      </view>
      <view class="stat-card stat-card--cancelled">
        <text class="stat-value">{{stats.cancelled}}</text>
        <text class="stat-label">已取消</text>
      </view>
    </view>
  </view>

  <view class="filter-card">
    <view class="search-row">
      <input
        class="search-input"
        placeholder="搜索活动标题或地点"
        value="{{keywordDraft}}"
        bindinput="onKeywordInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <button class="search-btn" bindtap="onSearch">搜索</button>
    </view>

    <scroll-view scroll-x class="status-scroll" show-scrollbar="false">
      <view class="chip-list chip-list--status">
        <block wx:for="{{statusOptions}}" wx:key="*this">
          <view class="chip {{selectedStatus === item ? 'chip--active' : ''}}" data-status="{{item}}" bindtap="onStatusTap">{{item}}</view>
        </block>
      </view>
    </scroll-view>

    <scroll-view scroll-x class="type-scroll" show-scrollbar="false">
      <view class="chip-list chip-list--type">
        <block wx:for="{{typeOptions}}" wx:key="*this">
          <view class="chip chip--light {{selectedType === item ? 'chip--active-light' : ''}}" data-type="{{item}}" bindtap="onTypeTap">{{item}}</view>
        </block>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="state-card">加载中...</view>
  <view wx:elif="{{!activities.length}}" class="state-card state-card--empty">
    <text class="state-title">暂无匹配活动</text>
    <text class="state-desc">可以尝试切换状态、类型，或清空搜索条件后再查看</text>
    <view class="state-btn" bindtap="clearKeyword">清空搜索</view>
  </view>

  <block wx:for="{{activities}}" wx:key="id">
    <view class="activity-card" bindtap="goManage" data-id="{{item.id}}">
      <view class="activity-card__top">
        <view class="badge-group">
          <text class="badge badge--status badge--{{item.statusMeta.className}}">{{item.statusText}}</text>
        </view>
        <text class="badge badge--visibility badge--visibility-{{item.visibilityClass}}">{{item.visibilityText}}</text>
      </view>

      <text class="activity-title">{{item.title}}</text>

      <view class="activity-meta-list">
        <view class="activity-meta-item">
          <text class="activity-meta-label">时间</text>
          <text class="activity-meta-value">{{item.timeText}}</text>
        </view>
        <view class="activity-meta-item">
          <text class="activity-meta-label">地点</text>
          <text class="activity-meta-value">{{item.placeText}}</text>
        </view>
        <view class="activity-meta-item activity-meta-item--inline">
          <text class="activity-meta-label">活动编号</text>
          <text class="activity-meta-value">{{item.codeText}}</text>
        </view>
      </view>

      <view class="activity-actions">
        <button class="action-btn action-btn--ghost" catchtap="goDetail" data-id="{{item.id}}">详情</button>
        <button
          class="action-btn action-btn--warn {{!item.canCancel ? 'action-btn--disabled' : ''}}"
          catchtap="onCancelTap"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          disabled="{{!item.canCancel}}"
        >取消活动</button>
        <button
          class="action-btn action-btn--danger {{!item.canDelete ? 'action-btn--disabled' : ''}}"
          catchtap="onDeleteTap"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          disabled="{{!item.canDelete}}"
        >删除</button>
      </view>

      <text class="manage-hint">点击卡片进入活动管理</text>
    </view>
  </block>
</view>
