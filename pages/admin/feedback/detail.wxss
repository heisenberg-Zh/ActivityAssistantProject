.detail-card {
  padding: 18rpx 18rpx 20rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f3f4f6;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #111827, #374151);
}

.avatar-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  padding: 8rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.badge--pending {
  background: rgba(245, 158, 11, 0.16);
  color: #b45309;
}

.badge--processing {
  background: rgba(59, 130, 246, 0.14);
  color: #1d4ed8;
}

.badge--resolved {
  background: rgba(16, 185, 129, 0.16);
  color: #047857;
}

.badge--closed {
  background: rgba(107, 114, 128, 0.14);
  color: #374151;
}

.sub-row {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.sub {
  font-size: 22rpx;
  color: #6b7280;
}

.detail-section {
  margin-top: 18rpx;
}

.section-label {
  font-size: 24rpx;
  color: #6b7280;
}

.section-content {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
  word-break: break-word;
}

.action-card {
  padding: 18rpx 18rpx 20rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.picker-value {
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #eef2f7;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

.note-input {
  min-height: 160rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #eef2f7;
  background: #ffffff;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
  width: 100%;
}

.note-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta {
  font-size: 22rpx;
  color: #9ca3af;
}

.save-btn {
  margin-top: 10rpx;
}

