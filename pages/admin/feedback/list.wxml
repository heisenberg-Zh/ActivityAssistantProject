<view class="section">
  <scroll-view scroll-x class="filter-scroll" show-scrollbar="{{false}}">
    <view class="filter-tabs">
      <block wx:for="{{statusTabs}}" wx:key="key">
        <view
          class="filter-tab {{statusFilter === item.key ? 'filter-tab--active' : ''}}"
          bindtap="switchStatus"
          data-key="{{item.key}}"
        >{{item.label}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索内容/联系方式"
      value="{{keyword}}"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
      bindinput="onKeywordInput"
    />
    <view class="search-btn" bindtap="doSearch">搜索</view>
  </view>
</view>

<view class="section">
  <block wx:if="{{items.length > 0}}">
    <block wx:for="{{items}}" wx:key="id">
      <view class="card shadow-card feedback-item" bindtap="openDetail" data-id="{{item.id}}">
        <view class="feedback-head">
          <view class="avatar">
            <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="avatar-fallback">
              <text class="avatar-text">{{item.avatarInitial}}</text>
            </view>
          </view>
          <view class="head-main">
            <view class="head-row">
              <text class="name">{{item.nickname || '匿名用户'}}</text>
              <view class="badge badge--{{item.status}}">{{item.statusText}}</view>
            </view>
            <view class="sub-row">
              <text class="sub">{{item.createdAtText}}</text>
              <text wx:if="{{item.typeText}}" class="sub">· {{item.typeText}}</text>
              <text wx:if="{{item.userId}}" class="sub">· {{item.userId}}</text>
            </view>
          </view>
        </view>
        <view class="feedback-body">
          <text class="content">{{item.content}}</text>
        </view>
      </view>
    </block>
  </block>

  <view wx:else class="empty-state">
    <text class="empty-title">暂无反馈</text>
    <text class="empty-sub">换个筛选条件试试</text>
  </view>
</view>

<view wx:if="{{loadingMore}}" class="loading-more">
  <text class="loading-text">加载中...</text>
</view>

