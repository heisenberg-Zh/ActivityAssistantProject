/* pages/activities/text-editor.wxss */
.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 24rpx;
}

.toolbar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
  border-bottom: 1px solid #eef2f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.toolbar-left, .toolbar-right {
  width: 220rpx;
  display: flex;
  align-items: center;
}

.toolbar-left { justify-content: flex-start; }
.toolbar-right { justify-content: flex-end; }

.toolbar-center {
  flex: 1;
  text-align: center;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.btn {
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
}

.btn--primary {
  background: #3b82f6;
  color: #ffffff;
}

.btn--ghost {
  background: #f3f4f6;
  color: #111827;
}

.meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx 0 24rpx;
}

.meta-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-btn {
  padding: 10rpx 16rpx;
  border-radius: 9999rpx;
  background: #dbeafe;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.meta-btn--danger {
  background: #fee2e2;
  color: #dc2626;
}

.counter {
  font-size: 24rpx;
  color: #6b7280;
}

.editor {
  padding: 18rpx 24rpx;
}

.textarea {
  width: 100%;
  min-height: 70vh;
  box-sizing: border-box;
  border: 1px solid #e5e7eb;
  border-radius: 20rpx;
  background: #ffffff;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
}
