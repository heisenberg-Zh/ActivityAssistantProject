<!-- pages/activities/detail.wxml -->

<!-- 无权限提示页面 -->
<view wx:if="{{!hasPermission}}" class="permission-denied-page">
  <view class="permission-denied-content">
    <text class="permission-icon">🔒</text>
    <text class="permission-title">无法查看此活动</text>
    <text class="permission-message">{{permissionDeniedReason}}</text>
    <text class="permission-hint">这是一个私密活动，仅创建者和已报名者可见</text>
    <view class="permission-actions">
      <!-- 如果是通过分享进来的，提供返回按钮 -->
      <button wx:if="{{fromShare}}" class="btn btn--primary" bindtap="goBack">返回</button>
      <!-- 如果不是通过分享进来的，提供返回首页按钮 -->
      <navigator wx:else url="/pages/home/index" open-type="switchTab" class="btn btn--primary">返回首页</navigator>
      <!-- 浏览公开活动按钮 -->
      <navigator url="/pages/activities/list" open-type="switchTab" class="btn btn--secondary">浏览公开活动</navigator>
    </view>
  </view>
</view>

<!-- 正常活动详情页面 -->
<view wx:else>
<view class="detail-header">
  <text class="detail-title">{{detail.title}}</text>
  <view class="favorite-icon {{isFavorited ? 'favorite-icon--active' : ''}}" bindtap="toggleFavorite">
    <view class="star-icon"></view>
  </view>
</view>

<view class="detail-cover-container">
  <image class="detail-cover-image" src="{{detail.imageUrl}}" mode="aspectFill"></image>
  <view class="detail-cover-overlay"></view>

  <!-- 活动类型标签 - 右上角 -->
  <view class="detail-type-badge">
    <text class="detail-type-text">{{detail.type}}</text>
  </view>

  <!-- 活动状态标签 - 左下角 -->
  <view class="detail-status-badge detail-status-badge--{{detail.statusClass}}">
    <text class="detail-status-text">{{detail.status}}</text>
  </view>

  <!-- 公开/私密标签 - 右下角 -->
  <view class="detail-privacy-badge detail-privacy-badge--{{detail.privacyClass}}">
    <text class="detail-privacy-text">{{detail.privacyText}}</text>
  </view>
</view>

<view class="section">
  <view class="card shadow-card detail-card">
    <view class="organizer">
      <!-- 组织者头像：优先图片，无图片则显示首字母 -->
      <view class="organizer-avatar-wrapper">
        <image
          wx:if="{{organizer.avatar}}"
          class="organizer-avatar-img"
          src="{{organizer.avatar}}"
          mode="aspectFill"
          binderror="onOrganizerAvatarError"
        />
        <view wx:else class="organizer-avatar">{{extra.organizerInitial}}</view>
      </view>
      <view class="flex-col">
        <text class="text-md text-gray-800">{{extra.organizer}}</text>
        <text class="text-xs text-gray-500">活动组织者</text>
      </view>

      <!-- 联系按钮 -->
      <view class="contact-buttons" wx:if="{{canViewContact}}">
        <!-- 电话按钮 -->
        <view wx:if="{{detail.organizerPhone}}" class="contact-btn contact-btn--v1" bindtap="callOrganizer" aria-label="拨打电话">
          <view class="contact-glyph contact-glyph--phone"></view>
        </view>
      </view>

      <!-- 未报名提示 -->
      <view class="contact-buttons-locked" wx:if="{{!canViewContact}}">
        <view class="contact-btn-locked">
          <view class="contact-icon contact-icon--lock"></view>
          <text class="contact-btn__text-gray">报名后可查看联系方式</text>
        </view>
      </view>
    </view>

    <view class="info-list">
      <view class="info-item">
        <view class="info-item__icon" style="background:#DBEAFE; color:#1d4ed8;">🕐</view>
        <view class="flex-col info-item__body">
          <text class="info-label">活动时间</text>
          <text class="info-value">{{detail.timeRange}}</text>
          <text class="info-hint">报名截止：{{extra.deadline}}</text>
        </view>
      </view>
      <view class="info-item" bindtap="openMap">
        <view class="info-item__icon" style="background:#DCFCE7; color:#047857;">📍</view>
        <view class="flex-col info-item__body">
          <text class="info-label">活动地点</text>
          <text class="info-value">{{detail.place}}</text>
          <text class="info-hint">{{extra.addressDetail}}</text>
        </view>
      </view>
      <view class="info-item">
        <view class="info-item__icon" style="background:#FDE68A; color:#B45309;">👥</view>
        <view class="flex-col info-item__body">
          <text class="info-label">参与人数</text>
          <text class="info-value">{{detail.joined}} / {{detail.total}} 人</text>
          <view class="progress mt-12"><view class="bar" style="width: {{progress}}%"></view></view>
        </view>
      </view>
      <view class="info-item">
        <view class="info-item__icon" style="background:#FEF3C7; color:#D97706;">🆔</view>
        <view class="flex-col info-item__body">
          <text class="info-label">活动编号</text>
          <text class="info-value">{{detail.id}}</text>
          <text class="info-hint">活动唯一标识</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 签到提示卡片（已审核通过时显示） -->
<view class="section" wx:if="{{detail.needCheckin !== false && isApproved && detail.status === '进行中'}}">
  <view class="card shadow-card checkin-notice-card">
    <view class="checkin-notice-icon">⏰</view>
    <view class="checkin-notice-content">
      <text class="checkin-notice-title" wx:if="{{isCheckedIn}}">已签到</text>
      <text class="checkin-notice-title" wx:elif="{{canCheckin}}">签到时间已到</text>
      <text class="checkin-notice-title" wx:else>活动进行中</text>
      <text class="checkin-notice-text" wx:if="{{isCheckedIn}}">{{checkinCheckedHint}}</text>
      <text class="checkin-notice-text" wx:elif="{{canCheckin}}">活动正在进行中，点击下方"签到"按钮完成签到</text>
      <text class="checkin-notice-text" wx:else>{{checkinTimeHint || '签到功能即将开放'}}</text>
    </view>
    <button class="btn btn--primary btn--small {{isCheckedIn ? 'btn--disabled' : ''}}" bindtap="goCheckin" disabled="{{!canCheckin || isCheckedIn}}">{{isCheckedIn ? '已签到' : (canCheckin ? '立即签到' : '暂不可签到')}}</button>
  </view>
</view>

<!-- 活动描述（有分组时：固定不随分组切换变化，展示在分组模块之上） -->
<view class="section" wx:if="{{detail.hasGroups && detail.desc}}">
  <view class="card shadow-card activity-desc-card">
    <view class="desc-header">
      <view class="desc-icon">📋</view>
      <text class="desc-title">活动描述</text>
    </view>
    <view class="desc-content">
      <text class="desc-text">{{detail.desc}}</text>
    </view>
  </view>
</view>

<!-- 分组信息 -->
<view class="section" wx:if="{{detail.hasGroups && detail.groups && detail.groups.length > 0}}">
  <view class="card shadow-card groups-section">
    <view class="groups-header">
      <text class="groups-title">活动分组</text>
      <text class="groups-subtitle">共 {{detail.groups.length}} 个分组</text>
    </view>

    <!-- 分组选择器 - 横向滚动 -->
    <scroll-view scroll-x class="groups-scroll" show-scrollbar="{{false}}">
      <view class="groups-tabs">
        <block wx:for="{{detail.groups}}" wx:key="id" wx:for-item="group" wx:for-index="idx">
          <view class="group-tab-card {{currentGroupIndex === idx ? 'group-tab-card--active' : ''}}" bindtap="switchGroup" data-index="{{idx}}">
            <view class="group-tab-header">
              <text class="group-tab-name">{{group.name}}</text>
              <view class="group-tab-status {{group.joined >= group.total ? 'status-full' : 'status-ok'}}">
                <text class="status-text">{{group.joined >= group.total ? '已满' : '可报'}}</text>
              </view>
            </view>
            <view class="group-tab-count">
              <text class="count-text">{{group.joined}}/{{group.total}} 人</text>
            </view>
          </view>
        </block>
      </view>
    </scroll-view>

    <!-- 当前分组详情 -->
    <view wx:if="{{detail.groups[currentGroupIndex]}}" class="group-detail-section">
      <!-- 审核提示 -->
      <view wx:if="{{detail.groups[currentGroupIndex].needReview}}" class="detail-info-card detail-info-card--review">
        <view class="info-icon">🔍</view>
        <view class="info-content">
          <text class="info-label">报名审核</text>
          <text class="info-text">本分组需要审核，报名后请耐心等待组织者审核通过</text>
        </view>
      </view>

      <!-- 费用信息 -->
      <view class="detail-info-card detail-info-card--primary">
        <view class="info-icon">💰</view>
        <view class="info-content">
          <text class="info-label">活动费用</text>
          <text class="info-value">{{detail.groups[currentGroupIndex].feeType}} {{detail.groups[currentGroupIndex].feeType !== '免费' ? '￥' + detail.groups[currentGroupIndex].fee : ''}}</text>
        </view>
      </view>

      <!-- 报名要求（随分组切换；若分组无值则回退到顶层 requirements；为空则隐藏） -->
      <view wx:if="{{detail.groups[currentGroupIndex].requirements || detail.requirements}}" class="detail-info-card detail-info-card--info">
        <view class="info-icon">📌</view>
        <view class="info-content">
          <text class="info-label">报名要求</text>
          <text class="info-text">{{detail.groups[currentGroupIndex].requirements || detail.requirements}}</text>
        </view>
      </view>

      <!-- 活动说明及注意事项（随分组切换；若分组无值则回退到顶层 description；为空则隐藏） -->
      <view wx:if="{{detail.groups[currentGroupIndex].description || detail.description}}" class="detail-info-card detail-info-card--info">
        <view class="info-icon">📝</view>
        <view class="info-content">
          <text class="info-label">活动说明及注意事项</text>
          <text class="info-text">{{detail.groups[currentGroupIndex].description || detail.description}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 无分组时的费用和说明信息 -->
<view class="section" wx:if="{{!detail.hasGroups}}">
  <view class="card shadow-card">
    <!-- 审核提示 -->
    <view wx:if="{{detail.needReview}}" class="info-item" style="background: #fef3c7; padding: 20rpx; border-radius: 12rpx; border-left: 4rpx solid #f59e0b; margin-bottom: 24rpx;">
      <view class="info-item__icon" style="background:#FEF3C7; color:#D97706;">🔍</view>
      <view class="flex-col info-item__body">
        <text class="info-label" style="color: #92400e;">报名审核</text>
        <text class="info-value" style="color: #78350f; font-size: 26rpx;">本活动需要审核，报名后请耐心等待组织者审核通过</text>
      </view>
    </view>

    <view class="info-item">
      <view class="info-item__icon" style="background:#E0E7FF; color:#4338CA;">💰</view>
      <view class="flex-col info-item__body">
        <text class="info-label">活动费用</text>
        <text class="info-value">{{extra.feeInfo}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 活动描述（醒目展示） -->
<view class="section" wx:if="{{!detail.hasGroups && detail.desc}}">
  <view class="card shadow-card activity-desc-card">
    <view class="desc-header">
      <view class="desc-icon">📋</view>
      <text class="desc-title">活动描述</text>
    </view>
    <view class="desc-content">
      <text class="desc-text">{{detail.desc}}</text>
    </view>
  </view>
</view>

<!-- 报名信息入口（仅创建者/管理员可见） -->
<view class="section" wx:if="{{canManage}}">
  <view class="card shadow-card participants-card">
    <view class="row-between mb-16">
      <text class="text-lg text-gray-800">报名信息（管理员可见）</text>
      <view class="text-sm text-blue-500" bindtap="goRegistrationManagement" hover-class="none">报名管理</view>
    </view>
    <text class="text-sm text-gray-500">可查看报名者填写的手机号、部门等报名信息</text>
  </view>
</view>

<view class="section">
  <view class="card shadow-card participants-card">
    <view class="row-between mb-16">
      <text class="text-lg text-gray-800">参与成员 ({{members.length}})</text>
      <view class="text-sm text-blue-500" bindtap="viewAllMembers" hover-class="none" wx:if="{{members.length > 0}}">查看全部</view>
    </view>
    <!-- 只展示一行头像（最多8个） -->
    <view class="participants-row" wx:if="{{members.length > 0}}">
      <block wx:for="{{members}}" wx:key="id" wx:for-item="item" wx:for-index="idx">
        <view wx:if="{{idx < 8}}" class="participants-avatar-item">
          <!-- 优先显示用户真实头像，否则显示首字母头像 -->
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="cover" class="participants-avatar-img" />
          <view wx:else class="participants-avatar-initial" style="background: {{item.bgColor}}">
            <text class="initial-text">{{item.initial}}</text>
          </view>
        </view>
      </block>
      <!-- 如果超过8个，显示更多提示 -->
      <view wx:if="{{members.length > 8}}" class="participants-more" bindtap="viewAllMembers">
        <text class="participants-more-text">+{{members.length - 8}}</text>
      </view>
    </view>
    <!-- 空状态 -->
    <view wx:if="{{members.length === 0}}" class="participants-empty">
      <text class="text-sm text-gray-400">暂无参与者</text>
    </view>
  </view>
</view>

<view class="bottom-space"></view>
<view class="fixed-footer">
  <button wx:if="{{canManage}}" class="btn btn--secondary footer-btn" bindtap="goManagement">管理</button>

  <!-- 已报名用户：显示签到或取消报名 -->
  <block wx:if="{{isRegistered}}">
    <!-- 如果已审核通过且活动进行中，显示签到按钮（根据签到时间窗口决定是否可点击） -->
    <button
      wx:if="{{detail.needCheckin !== false && isApproved && detail.status === '进行中'}}"
      class="btn {{isCheckedIn ? 'btn--disabled' : (canCheckin ? 'btn--primary' : 'btn--secondary')}} footer-btn"
      bindtap="goCheckin"
      disabled="{{!canCheckin || isCheckedIn}}">
      {{isCheckedIn ? '已签到' : (canCheckin ? '签到' : '签到未开放')}}
    </button>
    <!-- 否则显示取消报名按钮 -->
    <button
      wx:else
      class="btn btn--danger footer-btn"
      bindtap="cancelRegistration">
      取消报名
    </button>
  </block>

  <!-- 未报名用户：显示报名按钮 -->
  <button
    wx:else
    class="btn {{canRegister ? 'btn--primary' : 'btn--disabled'}} footer-btn"
    bindtap="goRegister"
    disabled="{{!canRegister}}">
    {{registerButtonText}}
  </button>
</view>
</view>
<!-- 结束 wx:else -->
