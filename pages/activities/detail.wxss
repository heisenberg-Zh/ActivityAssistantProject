/* pages/activities/detail.wxss */

/* 无权限提示页面 */
.permission-denied-page {
  min-height: 100vh;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.permission-denied-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 80rpx 48rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  max-width: 600rpx;
}

.permission-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.permission-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  display: block;
  margin-bottom: 16rpx;
}

.permission-message {
  font-size: 28rpx;
  color: #ef4444;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.permission-hint {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.permission-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  justify-content: center;
  align-items: center;
  width: 100%;
}

.permission-actions .btn {
  flex: 1;
  max-width: 280rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

/* 顶部标题栏 */
.detail-header {
  background: #ffffff;
  padding: 28rpx 24rpx;
  border-bottom: 1px solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.5;
  flex: 1;
  text-align: left;
}

/* 收藏图标 */
.favorite-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.favorite-icon:active {
  transform: scale(0.9);
}

/* 五角星图标 - 使用纯CSS绘制 */
.star-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  display: inline-block;
}

.star-icon::before {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
  color: #d1d5db;
  transition: all 0.3s ease;
}

/* 已收藏状态 - 黄色实心星 */
.favorite-icon--active .star-icon::before {
  color: #f59e0b;
  text-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.4);
}

/* 封面图片 */
.detail-cover {
  height: 320rpx;
  margin: 24rpx;
  border-radius: 32rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 24rpx;
  color: #ffffff;
  box-shadow: 0 12rpx 48rpx rgba(15, 23, 42, 0.12);
}

.cover-status {
  background: rgba(17,24,39,0.55);
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.cover-type {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(255,255,255,0.9);
  color: #1f2937;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 详情页图片样式 */
.detail-cover-container {
  margin: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
  height: 400rpx;
  box-shadow: 0 12rpx 48rpx rgba(15, 23, 42, 0.12);
}

.detail-cover-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.detail-cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0.4) 100%);
  z-index: 1;
}

/* 活动类型标签 - 右上角 */
.detail-type-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8rpx);
  padding: 16rpx 28rpx;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 3;
}

.detail-type-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  letter-spacing: 1rpx;
}

/* 活动状态标签 - 左下角 */
.detail-status-badge {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  z-index: 3;
  backdrop-filter: blur(8rpx);
}

/* 根据状态使用不同的颜色 */
.detail-status-badge--registering {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.detail-status-badge--ongoing {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

.detail-status-badge--ended {
  background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
}

.detail-status-badge--cancelled {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.detail-status-badge--full {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

/* 默认状态 */
.detail-status-badge {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
}

.detail-status-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 公开/私密标签 - 右下角 */
.detail-privacy-badge {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  padding: 16rpx 28rpx;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  z-index: 3;
  backdrop-filter: blur(8rpx);
}

.detail-privacy-badge--public {
  background: rgba(59, 130, 246, 0.95);
}

.detail-privacy-badge--private {
  background: rgba(239, 68, 68, 0.95);
}

.detail-privacy-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 移除旧的样式 */
.cover-status {
  display: none;
}

.cover-type {
  display: none;
}


.detail-card { padding: 24rpx 24rpx 32rpx 24rpx; }
.organizer { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.organizer-avatar-wrapper { width: 80rpx; height: 80rpx; }
.organizer-avatar-img { width: 80rpx; height: 80rpx; border-radius: 9999rpx; display: block; }
.organizer-avatar { width: 80rpx; height: 80rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: #ffffff; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; }

/* 联系按钮样式 */
.contact-buttons {
  display: flex;
  gap: 10rpx;
  margin-left: auto;
  flex-wrap: wrap;
  justify-content: flex-end;
  align-items: center;
}

.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;  /* 视觉更克制 */
  height: 64rpx; /* 点击区域仍足够 */
  box-sizing: border-box;
  color: #4B5563; /* 默认中性灰，更自然不突兀 */
  transition: all 0.15s ease;
}

/* 方案1：轻量圆形描边按钮 */
.contact-btn--v1 {
  border-radius: 9999rpx;
  border: 1rpx solid #E5E7EB;
  background: rgba(255, 255, 255, 0.7);
}

.contact-btn--v1:active {
  background: #F3F4F6;
  border-color: #D1D5DB;
  color: #2563EB; /* 按下态使用品牌蓝，反馈更清晰 */
  transform: scale(0.96);
}

/* 联系图标（更轻量的线性手机图标，使用 currentColor 继承颜色） */
.contact-glyph {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.contact-glyph--phone::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 32rpx;
  border: 2rpx solid currentColor;
  border-radius: 6rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -52%);
  box-sizing: border-box;
}

.contact-glyph--phone::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 9999rpx;
  bottom: 9rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 兼容锁定态图标的基础样式（锁定态仍复用 contact-icon 类名） */
.contact-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 50%;
}

/* 未报名用户看到的锁定状态 */
.contact-buttons-locked {
  margin-left: auto;
}

.contact-btn-locked {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
}

.contact-btn__text-gray {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 400;
}

/* 锁图标 */
.contact-icon--lock {
  width: 36rpx;
  height: 36rpx;
  background: #D1D5DB;
  color: #ffffff;
  font-size: 20rpx;
}

.contact-icon--lock::before {
  content: '🔒';
  font-size: 18rpx;
}

.info-list { display: flex; flex-direction: column; gap: 24rpx; }
.info-item { display: flex; align-items: flex-start; padding: 20rpx; background: #F9FAFB; border-radius: 16rpx; }
.info-item__icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.info-item__body { gap: 8rpx; flex: 1; }

/* 信息标签和值的样式 */
.info-label {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
  display: block;
}

.info-value {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 600;
  line-height: 1.5;
  display: block;
}

.info-hint {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.5;
  display: block;
}

.participants-card { padding: 24rpx; }

/* 参与者头像一行展示 */
.participants-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow-x: hidden;
}

.participants-avatar-item {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 3rpx solid #ffffff;
}

.participants-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
}

/* 首字母头像 */
.participants-avatar-initial {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.initial-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.participants-more {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 3rpx solid #ffffff;
}

.participants-more-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

.participants-empty {
  padding: 40rpx 0;
  text-align: center;
}

/* 旧样式保留以防其他地方使用 */
.participants-grid { display: flex; flex-wrap: wrap; gap: 24rpx 20rpx; }
.participants-item { width: 120rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.participants-avatar { width: 96rpx; height: 96rpx; border-radius: 9999rpx; }

.fixed-footer { position: fixed; left: 0; right: 0; bottom: 0; background: #ffffff; border-top: 1px solid #e5e7eb; padding: 16rpx 24rpx; display: flex; gap: 16rpx; }
.footer-btn { flex: 1; }
.fixed-footer--three-btn .footer-btn { flex: 0 0 calc((100% - 32rpx) / 3); min-width: 0; }

.icon-text { font-size: 28rpx; color: #4b5563; }

/* ===== 活动分组模块 ===== */
.groups-section {
  padding: 28rpx 24rpx;
}

/* 分组头部 */
.groups-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.groups-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.groups-subtitle {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* 横向滚动容器 */
.groups-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.groups-tabs {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

/* 分组卡片 */
.group-tab-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  min-width: 220rpx;
  padding: 20rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.group-tab-card:active {
  transform: scale(0.98);
}

.group-tab-card--active {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: #3b82f6;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
}

/* 卡片头部 */
.group-tab-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.group-tab-name {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-tab-card--active .group-tab-name {
  color: #1d4ed8;
}

/* 状态徽标 */
.group-tab-status {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
}

/* 签到提示卡片 */
.checkin-notice-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border-left: 4rpx solid #10b981;
  animation: pulse-border 2s ease-in-out infinite;
}

@keyframes pulse-border {
  0%, 100% {
    border-left-color: #10b981;
  }
  50% {
    border-left-color: #059669;
  }
}

.checkin-notice-icon {
  font-size: 56rpx;
  flex-shrink: 0;
  line-height: 1;
}

.checkin-notice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.checkin-notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #047857;
  line-height: 1.3;
}

.checkin-notice-text {
  font-size: 26rpx;
  color: #065f46;
  line-height: 1.5;
}

.checkin-notice-card .btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.status-ok {
  background: #d1fae5;
  color: #047857;
}

.status-full {
  background: #fee2e2;
  color: #dc2626;
}

.status-text {
  display: block;
}

/* 人数统计 */
.group-tab-count {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.count-text {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

.group-tab-card--active .count-text {
  color: #60a5fa;
  font-weight: 600;
}

/* 分组详情区域 */
.group-detail-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 详情信息卡片 */
.detail-info-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border-left: 4rpx solid;
}

.detail-info-card--primary {
  background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%);
  border-left-color: #3b82f6;
}

.detail-info-card--warning {
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border-left-color: #f59e0b;
}

.detail-info-card--info {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border-left-color: #10b981;
}

.detail-info-card--review {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-left-color: #f59e0b;
}

.info-icon {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-info-card .info-label {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

.detail-info-card .info-value {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 700;
}

.info-text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 活动描述卡片样式 */
.activity-desc-card {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-left: 4rpx solid #3b82f6;
  padding: 28rpx 32rpx;
  overflow: hidden;
}

.desc-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.desc-icon {
  font-size: 44rpx;
  line-height: 1;
  filter: drop-shadow(0 2rpx 8rpx rgba(59, 130, 246, 0.3));
}

.desc-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e40af;
  letter-spacing: 0.5rpx;
}

.desc-content {
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 2rpx 12rpx rgba(59, 130, 246, 0.08);
}

.desc-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  word-wrap: break-word;
  white-space: pre-wrap;
  display: block;
}
