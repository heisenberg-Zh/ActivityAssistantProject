<!-- pages/activities/text-editor.wxml -->
<view class="page">
  <view class="toolbar">
    <view class="toolbar-left">
      <view class="btn btn--ghost" bindtap="handleBack">返回</view>
    </view>
    <view class="toolbar-center">
      <text class="title">{{title}}</text>
    </view>
    <view class="toolbar-right">
      <view class="btn btn--primary" bindtap="handleSave">保存并返回</view>
    </view>
  </view>

  <view class="meta">
    <view class="meta-actions">
      <view class="meta-btn" bindtap="handlePaste">粘贴</view>
      <view class="meta-btn meta-btn--danger" bindtap="handleClear">清空</view>
    </view>
    <text class="counter">{{count}}/{{maxLength}}</text>
  </view>

  <view class="editor">
    <textarea
      class="textarea"
      value="{{text}}"
      maxlength="{{maxLength}}"
      placeholder="{{placeholder}}"
      cursor="{{cursor}}"
      bindfocus="onFocus"
      bindinput="onInput"
    />
  </view>
</view>
